#!/usr/bin/env bash
set -euo pipefail

: "${NEEDLETAIL_NODE_ID:=contrib}"
PLAN="${NEEDLETAIL_PLAN:-/etc/needletail/compiled-plan.json}"
SERVICE="$(jq -cer --arg node "${NEEDLETAIL_NODE_ID}" \
  '.services[] | select(.service == "av_contrib" and .node_id == $node)' "${PLAN}")"

args=(
  /usr/local/bin/av-contrib
  --cert /etc/needletail/tls/fullchain.pem
  --key /etc/needletail/tls/privkey.pem
  --http-port "${NEEDLETAIL_HTTP_PORT:-19443}"
  --mesh-fec-target "$(jq -r '.primary.target' <<<"${SERVICE}")"
  --mesh-media-fec-target "$(jq -r '.primary.target' <<<"${SERVICE}")"
  --stream-id 1
  --rist-stream-id 1
  --srt-stream-id 1
  --rtmp-stream-id 1
  --fmp4-part-ms "${NEEDLETAIL_PART_MS:-50}"
  --wall-clock-estimated-error-ms "${NEEDLETAIL_CLOCK_ERROR_MS:-5}"
  --rist-bind 0.0.0.0:27000
  --rist-flow-id 0x11223344
  --srt-bind 0.0.0.0:27001
  --rtmp-bind 0.0.0.0:19350
  --relay-local-id "${NEEDLETAIL_NODE_ID}"
  --relay-primary-bind "$(jq -r '.primary.bind' <<<"${SERVICE}")"
  --relay-primary-target "$(jq -r '.primary.target' <<<"${SERVICE}")"
  --relay-primary-id "$(jq -r '.primary.child_node_id' <<<"${SERVICE}")"
  --relay-secondary-bind "$(jq -r '.warm_secondary.bind' <<<"${SERVICE}")"
  --relay-secondary-target "$(jq -r '.warm_secondary.target' <<<"${SERVICE}")"
  --relay-secondary-id "$(jq -r '.warm_secondary.child_node_id' <<<"${SERVICE}")"
  --relay-secondary-seed-source
  --relay-exclusive
  --relay-topology-generation "$(jq -r '.topology_generation' <<<"${SERVICE}")"
  --relay-subscription-id "$(jq -r '.subscription_id' <<<"${SERVICE}")"
  --relay-deadline-ms "$(jq -r '.media_deadline_ms' <<<"${SERVICE}")"
)

if jq -e '.source_path_observation != null' <<<"${SERVICE}" >/dev/null; then
  args+=(
    --relay-path-loss-fraction "$(jq -r '.source_path_observation.loss_ppm / 1000000' <<<"${SERVICE}")"
    --relay-path-best-direct-rtt-ms "$(jq -r '.source_path_observation.best_direct_rtt_us / 1000' <<<"${SERVICE}")"
    --relay-path-rtt-ms "$(jq -r '.source_path_observation.rtt_us / 1000' <<<"${SERVICE}")"
    --relay-path-jitter-ms "$(jq -r '.source_path_observation.jitter_us / 1000' <<<"${SERVICE}")"
    --relay-path-queue-delay-ms "$(jq -r '.source_path_observation.queue_delay_us / 1000' <<<"${SERVICE}")"
  )
  if jq -e '.source_path_observation.observed_at_unix_ms != null' <<<"${SERVICE}" >/dev/null; then
    args+=(
      --relay-path-observed-at-unix-ms "$(jq -r '.source_path_observation.observed_at_unix_ms' <<<"${SERVICE}")"
    )
  fi
fi

if jq -e '.secondary_path_observation != null' <<<"${SERVICE}" >/dev/null; then
  args+=(
    --relay-secondary-path-loss-fraction "$(jq -r '.secondary_path_observation.loss_ppm / 1000000' <<<"${SERVICE}")"
    --relay-secondary-path-best-direct-rtt-ms "$(jq -r '.secondary_path_observation.best_direct_rtt_us / 1000' <<<"${SERVICE}")"
    --relay-secondary-path-rtt-ms "$(jq -r '.secondary_path_observation.rtt_us / 1000' <<<"${SERVICE}")"
    --relay-secondary-path-jitter-ms "$(jq -r '.secondary_path_observation.jitter_us / 1000' <<<"${SERVICE}")"
    --relay-secondary-path-queue-delay-ms "$(jq -r '.secondary_path_observation.queue_delay_us / 1000' <<<"${SERVICE}")"
  )
  if jq -e '.secondary_path_observation.observed_at_unix_ms != null' <<<"${SERVICE}" >/dev/null; then
    args+=(
      --relay-secondary-path-observed-at-unix-ms "$(jq -r '.secondary_path_observation.observed_at_unix_ms' <<<"${SERVICE}")"
    )
  fi
fi

exec "${args[@]}"
